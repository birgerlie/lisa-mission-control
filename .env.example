# Supabase Configuration
# Get these values from your Supabase project dashboard: https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Webhook Configuration
WEBHOOK_SECRET=your-webhook-secret-here
WEBHOOK_URL=http://localhost:18789/webhook/task

# Cron Job Secret
CRON_SECRET=your-cron-secret-here

# Optional: Custom Database Path (for local development)
# DATABASE_PATH=./data/mission-control.db
